{
  "name": "@syncora/frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev -p 5173",
    "build": "next build",
    "start": "next start -p 5173",
    "lint": "eslint \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.ts\"",
    "test": "echo \"No unit tests yet\"",
    "e2e:install": "playwright install chromium",
    "e2e": "npm run e2e:install && playwright test",
    "e2e:watch": "PW_HEADED=1 playwright test --headed --workers=1",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "npm run e2e:watch",
    "e2e:debug": "playwright test --debug --workers=1",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@syncora/shared": "0.1.0",
    "@tanstack/react-query": "^5.0.0",
    "next": "^15.0.0",
    "next-themes": "^0.4.6",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0"
  }
}
