# Copier vers `.env.local` : cp .env.local.example .env.local

# Widget Crisp (Settings > Setup & integrations > Website ID)
NEXT_PUBLIC_CRISP_WEBSITE_ID=f768cb2c-0a67-4daf-a64f-c8ac005c5827

# Centre d'aide (Helpdesk / Knowledge Base) — après activation dans Crisp (Plugins > Helpdesk)
# NEXT_PUBLIC_CRISP_HELPDESK_ENABLED=true

# Optionnel côté gateway (Settings > Website Settings > Advanced > Identity verification)
# Obligatoire si la vérification d'identité est activée dans Crisp, sinon l'email sera rejeté.
# CRISP_IDENTITY_SECRET=
