# Copier vers `.env.local` : cp .env.local.example .env.local

# Widget Crisp (Settings > Setup & integrations > Website ID)
NEXT_PUBLIC_CRISP_WEBSITE_ID=f768cb2c-0a67-4daf-a64f-c8ac005c5827

# Centre d'aide (Helpdesk / Knowledge Base) — après activation dans Crisp (Plugins > Helpdesk)
# NEXT_PUBLIC_CRISP_HELPDESK_ENABLED=true

# Accès mobile / LAN : pointer l’API vers l’IP locale de votre machine (même IP que ci-dessous côté gateway).
# NEXT_PUBLIC_API_URL=http://192.168.1.34:3000/api
# NEXT_PUBLIC_MARKETING_HOST=planwise.fr
# NEXT_PUBLIC_APP_HOST=app.planwise.fr

# Version applicative (injectée automatiquement par la CD en prod ; "dev" en local si vide).
# NEXT_PUBLIC_APP_VERSION=
# NEXT_PUBLIC_GIT_SHA=

# Informations légales éditeur (mentions légales, CGU/CGV, confidentialité)
# NEXT_PUBLIC_LEGAL_PUBLISHER_NAME=Planwise
# NEXT_PUBLIC_LEGAL_COMPANY_NAME=Benoist Babin
# NEXT_PUBLIC_LEGAL_LEGAL_FORM=Entrepreneur individuel
# NEXT_PUBLIC_LEGAL_SIRET=97910280300017
# NEXT_PUBLIC_LEGAL_RCS=Brest 979 102 803
# NEXT_PUBLIC_LEGAL_VAT=FR11979102803
# NEXT_PUBLIC_LEGAL_ADDRESS=2 rue Saint-Saëns, 29800 Landerneau, France
# NEXT_PUBLIC_LEGAL_DIRECTOR=Benoist Babin
# NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=contact@planwise.fr
# NEXT_PUBLIC_LEGAL_DPO_EMAIL=contact@planwise.fr
# NEXT_PUBLIC_LEGAL_HOST_NAME=OVH SAS
# NEXT_PUBLIC_LEGAL_HOST_ADDRESS=2 rue Kellermann, 59100 Roubaix, France

# Optionnel côté gateway (`services/api-gateway/.env`, pas ici)
# Settings > Website Settings > Advanced > Identity verification
# CRISP_IDENTITY_SECRET=
# CORS_ORIGIN=http://localhost:5173,http://192.168.1.34:5173
#
# Test PWA sur mobile (Chrome Android, HTTP LAN) :
# 1. Lancer le backend + `npm run pwa:preview` (pas `npm run dev` : le SW est désactivé en dev)
# 2. Sur le téléphone : chrome://flags/#unsafely-treat-insecure-origin-as-secure
#    → saisir http://192.168.1.34:5173 (schéma + IP + port, sans slash final)
#    → activer le flag → Relaunch Chrome
# 3. Ouvrir http://192.168.1.34:5173 — l’invite « Installer l’app » ou le menu ⋮ → « Installer l’application »
