# Copier vers deploy/.env.production puis renseigner les valeurs.
# Ce fichier ne doit JAMAIS contenir de secrets réels versionnés (.env.production est gitignoré).

# ── Images Docker ────────────────────────────────────────────
# Préfixe du registry (sans slash final). Exemple GHCR : ghcr.io/mon-org
REGISTRY=ghcr.io/CHANGE_ME
# Tag des images à déployer. Surchargé puis **persisté** par la CD au déploiement
# (= version SemVer fournie, ex: v0.1.0, sinon SHA court du commit).
# Un `docker compose up` manuel utilise cette valeur : la laisser à jour évite
# de revenir à une ancienne image.
IMAGE_TAG=latest

# ── Domaines & HTTPS ─────────────────────────────────────────
# Landing marketing (apex) + application (sous-domaine app)
MARKETING_DOMAIN=exemple.fr
APP_DOMAIN=app.exemple.fr
API_DOMAIN=api.exemple.fr
# Grafana (profil monitoring) — enregistrement DNS A obligatoire
MONITORING_DOMAIN=monitoring.exemple.fr
ACME_EMAIL=admin@exemple.fr

# ── Sécurité API ─────────────────────────────────────────────
# Générer une valeur forte : openssl rand -hex 48
JWT_SECRET=
# Origines autorisées (le frontend public). Plusieurs valeurs séparées par des virgules en local uniquement.
CORS_ORIGIN=https://app.exemple.fr

# ── Base de données ──────────────────────────────────────────
# Mongo embarqué (compose) : laisser la valeur par défaut.
# Mongo managé : mettre l'URI de base SANS nom de base (il est ajouté par service),
# ou surcharger chaque MONGODB_URI directement dans le compose.
MONGO_BASE_URI=mongodb://mongodb:27017

# ── Stripe (subscriptions-service) ───────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_TRIAL_DAYS=15
STRIPE_WEBHOOK_SECRET=
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=
# URLs CGV/CGU dans Stripe Checkout (défaut : https://MARKETING_DOMAIN/cgv et /cgu)
STRIPE_LEGAL_MARKETING_URL=https://exemple.fr
STRIPE_CGV_URL=
STRIPE_CGU_URL=
STRIPE_ADDON_TEAM_SUGGESTION_PRICE_ID=
STRIPE_ADDON_EXTRA_USERS_PRICE_ID=

# ── Crisp (support) ──────────────────────────────────────────
# Secret de vérification d'identité (gateway, jamais exposé côté client).
CRISP_IDENTITY_SECRET=

# ── Notifications push (VAPID) ───────────────────────────────
# Générer une paire gratuite : npx web-push generate-vapid-keys
# La clé publique est transmise au navigateur ; la clé privée reste uniquement côté serveur.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@planwise.fr

# ── Email transactionnel (notifications-service, SMTP) ───────
# Offre MX Plan OVH (boîte dédiée, ex. notifications@planwise.fr) :
#   SMTP_HOST=ssl0.ovh.net
#   SMTP_PORT=465          (SSL direct — recommandé OVH ; 587 + STARTTLS possible)
#   SMTP_USER=notifications@planwise.fr
#   SMTP_PASS=<mot de passe de la boîte>
#   SMTP_FROM=Planwise <notifications@planwise.fr>
# Limite MX Plan : ~200 e-mails/heure. Configurer SPF, DKIM et DMARC sur le domaine.
# Le champ From doit rester en ASCII pur (pas d'accents ni tirets typographiques).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Planwise <notifications@planwise.fr>
# URL du frontend (liens « Voir dans Planwise » dans les e-mails).
APP_URL=https://app.exemple.fr

# ── Stockage documents ───────────────────────────────────────
# local (volume Docker, défaut MVP) ou s3 (Object Storage, recommandé à terme).
STORAGE_PROVIDER=local
# Requis seulement si STORAGE_PROVIDER=s3 :
S3_BUCKET=
S3_ENDPOINT=
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Swagger (optionnel) ──────────────────────────────────────
SWAGGER_PATH=api/docs
SWAGGER_TITLE=Planwise API Gateway

# ── Frontend (build-time uniquement — ne pas renseigner sur le serveur) ──
# Injectées au BUILD de l'image frontend par la CD (Variables GitHub + input version).
# Non lues au runtime par docker-compose.
NEXT_PUBLIC_API_URL=https://api.exemple.fr/api
NEXT_PUBLIC_MARKETING_HOST=exemple.fr
NEXT_PUBLIC_APP_HOST=app.exemple.fr
NEXT_PUBLIC_CRISP_WEBSITE_ID=
NEXT_PUBLIC_CRISP_HELPDESK_ENABLED=false
# Version + SHA : injectés automatiquement par la CD. Affichés dans l'app (Mon compte).
NEXT_PUBLIC_APP_VERSION=
NEXT_PUBLIC_GIT_SHA=
# Mentions légales / CGU / confidentialité (build-time)
NEXT_PUBLIC_LEGAL_PUBLISHER_NAME=Planwise
NEXT_PUBLIC_LEGAL_COMPANY_NAME=Benoist Babin
NEXT_PUBLIC_LEGAL_LEGAL_FORM=Entrepreneur individuel
NEXT_PUBLIC_LEGAL_SIRET=97910280300017
NEXT_PUBLIC_LEGAL_RCS=Brest 979 102 803
NEXT_PUBLIC_LEGAL_VAT=FR11979102803
NEXT_PUBLIC_LEGAL_SHARE_CAPITAL=
NEXT_PUBLIC_LEGAL_ADDRESS=2 rue Saint-Saëns, 29800 Landerneau, France
NEXT_PUBLIC_LEGAL_DIRECTOR=Benoist Babin
NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=contact@planwise.fr
NEXT_PUBLIC_LEGAL_DPO_EMAIL=contact@planwise.fr
NEXT_PUBLIC_LEGAL_HOST_NAME=OVH SAS
NEXT_PUBLIC_LEGAL_HOST_ADDRESS=2 rue Kellermann, 59100 Roubaix, France

# ── Intégrations (Pennylane, Qonto) ───────────────────────────
# Clé AES-256 (64 caractères hex) : openssl rand -hex 32
INTEGRATIONS_ENCRYPTION_KEY=
# Optionnel — sandbox / override API
PENNYLANE_API_BASE_URL=https://app.pennylane.com/api/external/v2
# OAuth app (Partnerships Pennylane) — active le bouton « Connecter avec Pennylane »
# Redirect URI à déclarer chez Pennylane (doit matcher APP_URL) :
#   https://app.exemple.fr/settings/integrations/pennylane/callback
PENNYLANE_CLIENT_ID=
PENNYLANE_CLIENT_SECRET=
# Optionnel si APP_URL est défini (dérivé automatiquement)
# PENNYLANE_OAUTH_REDIRECT_URI=https://app.exemple.fr/settings/integrations/pennylane/callback
# PENNYLANE_OAUTH_SCOPES=customers:all customer_invoices:all

# Qonto — OAuth app (active le bouton « Connecter avec Qonto »)
# Redirect URI à déclarer chez Qonto :
#   https://app.exemple.fr/settings/integrations/qonto/callback
QONTO_API_BASE_URL=https://thirdparty.qonto.com/v2
QONTO_CLIENT_ID=
QONTO_CLIENT_SECRET=
# Optionnel si APP_URL est défini (dérivé automatiquement)
# QONTO_OAUTH_REDIRECT_URI=https://app.exemple.fr/settings/integrations/qonto/callback
# QONTO_OAUTH_SCOPES=organization.read offline_access client.read client.write client_invoice.read client_invoice.write
# Sandbox local uniquement (voir services/integrations-service/.env.example) :
# QONTO_STAGING_TOKEN=
# QONTO_OAUTH_AUTHORIZE_URL=https://oauth-sandbox.staging.qonto.co/oauth2/auth
# QONTO_OAUTH_TOKEN_URL=https://oauth-sandbox.staging.qonto.co/oauth2/token

# ── Monitoring Grafana (profil monitoring, optionnel) ────────
# Générer un mot de passe fort : openssl rand -base64 24
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
# Port local sur la VM (127.0.0.1 — tunnel SSH de secours)
GRAFANA_PORT=3030
# URL publique (doit correspondre à MONITORING_DOMAIN)
GRAFANA_ROOT_URL=https://monitoring.exemple.fr

# ── Traces APM (OpenTelemetry → Tempo, profil monitoring) ────
# Activer quand la stack monitoring tourne (otel-collector sur le réseau planwise).
OTEL_TRACES_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
