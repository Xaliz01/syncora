# Copier vers `.env` : cp .env.example .env
#
# ── Chiffrement local (obligatoire pour stocker les tokens) ──
# openssl rand -hex 32
INTEGRATIONS_ENCRYPTION_KEY=

# URL de l’app frontend (dérive le redirect OAuth si QONTO_OAUTH_REDIRECT_URI est vide)
APP_URL=http://localhost:5173

# ── Qonto sandbox (tests locaux) ─────────────────────────────
# Docs : https://docs.qonto.com/get-started/business-api/authentication/oauth/sandbox
# Basculer le Developer Portal en mode Sandbox, puis copier client id/secret + staging token.
QONTO_API_BASE_URL=https://thirdparty-sandbox.staging.qonto.co/v2
QONTO_OAUTH_AUTHORIZE_URL=https://oauth-sandbox.staging.qonto.co/oauth2/auth
QONTO_OAUTH_TOKEN_URL=https://oauth-sandbox.staging.qonto.co/oauth2/token
QONTO_CLIENT_ID=
QONTO_CLIENT_SECRET=
# Token personnel Developer Portal — header X-Qonto-Staging-Token (obligatoire en sandbox)
QONTO_STAGING_TOKEN=
# Redirect à déclarer dans l’app Qonto sandbox :
#   http://localhost:5173/settings/integrations/qonto/callback
# QONTO_OAUTH_REDIRECT_URI=http://localhost:5173/settings/integrations/qonto/callback
# QONTO_OAUTH_SCOPES=organization.read offline_access client.read client.write client_invoice.read client_invoice.write

# ── Qonto production (ne pas mélanger avec le sandbox) ───────
# QONTO_API_BASE_URL=https://thirdparty.qonto.com/v2
# QONTO_OAUTH_AUTHORIZE_URL=https://oauth.qonto.com/oauth2/auth
# QONTO_OAUTH_TOKEN_URL=https://oauth.qonto.com/oauth2/token
# QONTO_CLIENT_ID=
# QONTO_CLIENT_SECRET=
# (pas de QONTO_STAGING_TOKEN en production)
