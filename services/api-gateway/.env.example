# Copier vers `.env` : cp .env.example .env
#
# Crisp — Settings > Website Settings > Advanced > Identity verification
# (ne jamais exposer côté frontend)
CRISP_IDENTITY_SECRET=

# Backoffice plateforme
# PLATFORM_STAFF_EMAILS=mail@benoistbabin.fr
# PLATFORM_STAFF_EMAIL_DOMAINS=planwise.fr

# Accès depuis un téléphone / autre machine sur le réseau local (dev uniquement).
# Remplacer 192.168.x.x par l’IP LAN de votre machine (ifconfig / ipconfig).
# CORS_ORIGIN=http://localhost:5173,http://192.168.1.34:5173
